# CLI Agent 配置文件
# 复制为 cli_agent.yaml 后填入实际值，此文件不入版本控制

# LLM 配置
api_key: sk-your-api-key-here
model: deepseek:deepseek-chat          # 支持 provider:model 或 url:model
# url: https://api.deepseek.com/chat/completions  # 可选，覆盖默认 URL

# Python skill 搜索目录（支持 ~ 展开）
skill_dirs:
  - src/agentmatrix/desktop/skills

# 初始 skill 列表（为空则使用默认 base,file,shell）
skills:
  - cdp_browser
  - file
  - shell

# 自定义 system prompt（可选，与 system_prompt_file 二选一）
# system_prompt: "你是一个浏览器自动化助手。"
# system_prompt_file: prompts/browser_agent.txt
