{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "AgentMatrix",
  "version": "1.0.0",
  "identifier": "com.agentmatrix.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "splash",
        "url": "splash.html",
        "width": 400,
        "height": 280,
        "resizable": false,
        "decorations": false,
        "visible": false
      },
      {
        "label": "wizard",
        "title": "AgentMatrix — Setup",
        "url": "index.html",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 650,
        "resizable": true,
        "visible": false
      },
      {
        "label": "main",
        "title": "AgentMatrix",
        "url": "index.html",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "visible": false
      },
      {
        "label": "floating-capsule",
        "url": "capsule.html",
        "width": 300,
        "height": 72,
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false
      },
      {
        "label": "floating-stream",
        "url": "stream.html",
        "width": 453,
        "height": 224,
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false
      },
      {
        "label": "input",
        "url": "input.html",
        "width": 480,
        "height": 320,
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "backgroundColor": "#00000000"
      },
      {
        "label": "detail",
        "url": "detail.html",
        "width": 480,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visible": false,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/matrix-template/**/*",
      "resources/python_dist/**/*"
    ],
    "externalBin": [],
    "macOS": {
      "signingIdentity": "-",
      "entitlements": null,
      "hardenedRuntime": false
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
