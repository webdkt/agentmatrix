{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "AgentMatrix",
  "version": "1.0.0",
  "identifier": "com.agentmatrix.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "title": "AgentMatrix",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/matrix-template/**/*",
      "resources/podman/**/*",
      "resources/docker/**/*"
    ],
    "externalBin": [
      "binaries/server",
      "binaries/server-aarch64-apple-darwin",
      "binaries/server-x86_64-apple-darwin",
      "binaries/server-x86_64-pc-windows-msvc.exe"
    ],
    "macOS": {
      "signingIdentity": "-",
      "entitlements": null,
      "hardenedRuntime": false
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
