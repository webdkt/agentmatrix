{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "AgentMatrix",
  "version": "1.0.0",
  "identifier": "com.agentmatrix.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgentMatrix",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/matrix-template/**/*",
      "resources/podman/**/*"
    ],
    "externalBin": [
      "binaries/server"
    ]
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "binaries/server*",
          "sidecar": true
        },
        {
          "name": "podman*",
          "sidecar": false
        },
        {
          "name": "open",
          "args": true
        }
      ]
    }
  }
}
