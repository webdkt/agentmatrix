name: Build Desktop App

on:
  push:
    tags:
      - 'v*'
  workflow_dispatch:
    inputs:
      variant:
        description: 'Build variant'
        required: true
        default: 'full'
        type: choice
        options:
          - full
          - slim
          - both

env:
  PYTHON_VERSION: '3.12'

jobs:
  build:
    if: |
      (github.event_name != 'workflow_dispatch') ||
      (inputs.variant == 'both') ||
      (inputs.variant == 'full' && matrix.variant == 'full') ||
      (inputs.variant == 'slim' && matrix.variant == 'slim')
    strategy:
      fail-fast: false
      matrix:
        include:
          - os: macos-latest
            target: aarch64-apple-darwin
            variant: full
          - os: macos-latest
            target: aarch64-apple-darwin
            variant: slim
          - os: macos-latest
            target: x86_64-apple-darwin
            variant: full
          - os: macos-latest
            target: x86_64-apple-darwin
            variant: slim
          - os: windows-latest
            target: x86_64-pc-windows-msvc
            variant: full
          - os: windows-latest
            target: x86_64-pc-windows-msvc
            variant: slim

    runs-on: ${{ matrix.os }}

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      # ==================== Python Backend Build ====================
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: ${{ env.PYTHON_VERSION }}
          cache: 'pip'

      - name: Install Python dependencies
        run: |
          python -m pip install --upgrade pip
          pip install pyinstaller
          pip install -r requirements.txt

      - name: Build Python backend with PyInstaller
        run: |
          pyinstaller server.spec --distpath dist-server

      - name: Verify server executable
        shell: bash
        run: |
          if [ "${{ matrix.os }}" = "windows-latest" ]; then
            ls -la dist-server/server/server.exe
          else
            ls -la dist-server/server/server
          fi

      # ==================== Podman Installer (Full variant only) ====================
      - name: Download Podman installer (macOS)
        if: matrix.variant == 'full' && matrix.os == 'macos-latest'
        run: |
          mkdir -p agentmatrix-desktop/src-tauri/resources/podman
          curl -L -o agentmatrix-desktop/src-tauri/resources/podman/Podman.dmg \
            "https://github.com/containers/podman-desktop/releases/latest/download/podman-desktop-latest-mac.dmg"

      - name: Download Podman installer (Windows)
        if: matrix.variant == 'full' && matrix.os == 'windows-latest'
        run: |
          mkdir -p agentmatrix-desktop/src-tauri/resources/podman
          curl -L -o agentmatrix-desktop/src-tauri/resources/podman/podman.msi \
            "https://github.com/containers/podman/releases/latest/download/podman-v5.0.0-setup-x64.msi"
      # ==================== Docker Image (Full variant only) ====================
      # NOTE: Docker image build skipped on macOS (runners don't have Docker)
      # Windows builds the x86_64 Docker image for all platforms
      
      - name: Build and export Docker image
        if: matrix.variant == 'full' && matrix.os == 'windows-latest'
        shell: bash
        run: |
          # Windows has Docker pre-installed
          docker build -t agentmatrix:latest .
          mkdir -p agentmatrix-desktop/src-tauri/resources/docker
          docker save agentmatrix:latest | gzip > agentmatrix-desktop/src-tauri/resources/docker/image.tar.gz
          ls -lh agentmatrix-desktop/src-tauri/resources/docker/image.tar.gz

      # ==================== Copy Server to Tauri Sidecar ====================
      - name: Copy server to sidecar directory
        shell: bash
        run: |
          mkdir -p agentmatrix-desktop/src-tauri/binaries
          if [ "${{ matrix.os }}" = "windows-latest" ]; then
            cp -r dist-server/server/* agentmatrix-desktop/src-tauri/binaries/
          else
            cp dist-server/server/server agentmatrix-desktop/src-tauri/binaries/server-${{ matrix.target }}
            chmod +x agentmatrix-desktop/src-tauri/binaries/server-${{ matrix.target }}
          fi

      # ==================== Frontend Build ====================
      - name: Install Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'
          cache-dependency-path: 'agentmatrix-desktop/package-lock.json'

      - name: Install Rust
        uses: dtolnay/rust-toolchain@stable
        with:
          targets: ${{ matrix.target }}

      - name: Install Linux dependencies
        if: matrix.os == 'ubuntu-latest'
        run: |
          sudo apt-get update
          sudo apt-get install -y libgtk-3-dev libwebkit2gtk-4.0-dev libappindicator3-dev librsvg2-dev patchelf

      - name: Install frontend dependencies
        working-directory: agentmatrix-desktop
        run: npm install

      # ==================== Tauri Build ====================
      - name: Build Tauri application
        working-directory: agentmatrix-desktop
        run: npm run tauri:build
        env:
          TAURI_PRIVATE_KEY: ${{ secrets.TAURI_PRIVATE_KEY }}
          TAURI_KEY_PASSWORD: ${{ secrets.TAURI_KEY_PASSWORD }}

      # ==================== Rename Artifacts with Variant ====================
      - name: Rename artifacts with variant
        shell: bash
        run: |
          VERSION=$(echo "${{ github.ref_name }}" | sed 's/^v//')
          VARIANT="${{ matrix.variant }}"
          
          BUNDLE_DIR="agentmatrix-desktop/src-tauri/target/release/bundle"
          
          # macOS
          if [ -d "$BUNDLE_DIR/macos" ]; then
            for dmg in $BUNDLE_DIR/macos/*.dmg; do
              if [ -f "$dmg" ]; then
                mv "$dmg" "${dmg%.dmg}-${VARIANT}.dmg"
              fi
            done
          fi
          
          # Windows
          if [ -d "$BUNDLE_DIR/msi" ]; then
            for msi in $BUNDLE_DIR/msi/*.msi; do
              if [ -f "$msi" ]; then
                mv "$msi" "${msi%.msi}-${VARIANT}.msi"
              fi
            done
          fi

      # ==================== Upload Artifacts ====================
      - name: Upload artifacts
        uses: actions/upload-artifact@v4
        with:
          name: ${{ matrix.target }}-${{ matrix.variant }}-build
          path: |
            agentmatrix-desktop/src-tauri/target/release/bundle/
            agentmatrix-desktop/src-tauri/target/*/release/bundle/
          retention-days: 7

  release:
    needs: build
    runs-on: ubuntu-latest
    if: startsWith(github.ref, 'refs/tags/')

    steps:
      - name: Download all artifacts
        uses: actions/download-artifact@v4

      - name: Create Release
        uses: softprops/action-gh-release@v1
        with:
          files: |
            **/*/*.dmg
            **/*/*.app.tar.gz
            **/*/*.deb
            **/*/*.AppImage
            **/*/*.msi
            **/*.exe
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
