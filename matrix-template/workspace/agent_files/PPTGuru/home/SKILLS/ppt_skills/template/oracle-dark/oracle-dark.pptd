title: Oracle Dark
size:
- 1280
- 720
theme:
  colors:
    primary: '#04536F'
    secondary: '#6C3F49'
    accent: '#C74634'
    background: '#2A2F2F'
    text: '#FFFFFF'
    textLight: '#99ADAE'
    border: '#8B8580'
    tableAlt: '#464F4F'
    highlight: '#F0CC71'
    cardBg: '#464F4F'
    cardAccent: '#99ADAE'
    white: '#FFFFFF'
    darkBg: '#2A2F2F'
  textStyles:
    title:
      fontSize: 36
      color: $text
      fontFamily: Georgia, MiSans
      lineHeight: 1.2
    subtitle:
      fontSize: 20
      color: $textLight
      fontFamily: Georgia, MiSans
      lineHeight: 1.4
    actionTitle:
      fontSize: 28
      color: $text
      fontFamily: Georgia, MiSans
      lineHeight: 1.3
    body:
      fontSize: 16
      color: $text
      fontFamily: Georgia, MiSans
      lineHeight: 1.5
    caption:
      fontSize: 14
      color: $textLight
      fontFamily: Georgia, MiSans
      lineHeight: 1.4
    footnote:
      fontSize: 10
      color: $textLight
      fontFamily: Georgia, MiSans
      lineHeight: 1.4
    pageNumber:
      fontSize: 10
      color: $textLight
      fontFamily: Georgia, MiSans
      lineHeight: 1.0
  tableStyles:
    default:
      fontSize: 12
      fontFamily: Georgia, MiSans
      headerFill: $background
      headerColor: $highlight
      headerBold: true
      bodyFill:
      - $background
      - $tableAlt
      bodyColor: $text
      firstColumnBold: true
      border:
        style: solid
        width: 1
        color: $border
pages:
- pages/cover.page
- pages/table_of_contents.page
- pages/chapter.page
- pages/content_left_right.page
- pages/content_table.page
- pages/final.page
