# 极简基础镜像 - 容器包延迟加载架构
# 目标大小: ~150MB
# 此镜像只包含基础运行时，重型依赖通过 install_packages.sh 在首次运行时安装
# 镜像源配置在运行时根据网络环境自动选择（国内外自适应）

FROM python:3.12-slim

# 安装基础系统工具（最小化）
# 使用官方源构建，运行时自动选择最佳镜像源
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    curl \
    wget \
    ca-certificates \
    sqlite3 \
    git \
    bc \
    # 清理缓存
    && rm -rf /var/lib/apt/lists/*

# 安装 Node.js 20.x（但不安装全局包）
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# 配置 npm 镜像（但不安装包）
RUN npm config set registry https://registry.npmmirror.com

# 安装最小 Python 依赖（只包含核心框架）
COPY requirements-minimal.txt /tmp/
RUN pip install --no-cache-dir -r /tmp/requirements-minimal.txt

# 创建目录结构
RUN mkdir -p /data/agents /opt/ms-playwright

# 使用根目录作为默认工作目录
WORKDIR /

# 设置环境变量
ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    NODE_PATH=/usr/lib/node_modules \
    # Playwright 浏览器安装到共享路径
    PLAYWRIGHT_BROWSERS_PATH=/opt/ms-playwright

# 保持容器运行
CMD ["tail", "-f", "/dev/null"]
